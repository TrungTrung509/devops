        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "text": {}
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum by (le, read_mode) (rate(csdlpt_course_read_duration_seconds_bucket{endpoint=\"list\",read_mode=~\"local|remote\"}[5m])))",
          "legendFormat": "{{read_mode}}",
          "refId": "A"
        }
      ],
      "title": "Course List p95 Latency",
      "type": "bargauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "text": {}
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (read_mode) (rate(csdlpt_course_read_duration_seconds_sum{endpoint=\"list\",read_mode=~\"local|remote\"}[5m])) / sum by (read_mode) (rate(csdlpt_course_read_duration_seconds_count{endpoint=\"list\",read_mode=~\"local|remote\"}[5m]))",
          "legendFormat": "{{read_mode}}",
          "refId": "A"
        }
      ],
      "title": "Course List Avg Latency",
      "type": "bargauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "id": 3,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (read_mode) (rate(csdlpt_course_read_requests_total{endpoint=\"list\",read_mode=~\"local|remote\",status=\"200\"}[5m]))",
          "legendFormat": "{{read_mode}}",
          "refId": "A"
        }
      ],
      "title": "Course List Throughput",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 9
      },
      "id": 4,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "editorMode": "code",
          "expr": "sum by (read_mode, served_site) (increase(csdlpt_course_read_requests_total{endpoint=\"list\",read_mode=~\"local|remote\",status=\"200\"}[15m]))",
          "legendFormat": "{{read_mode}} -> {{served_site}}",
          "refId": "A"
        }
      ],
      "title": "Successful Reads by Served Site (15m)",
      "type": "timeseries"
    }
  ],
  "refresh": "15s",
  "schemaVersion": 41,
  "tags": [
    "csdlpt",
    "benchmark",
    "courses"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timezone": "browser",
  "title": "CSDLPT Course Read Comparison",
  "version": 1,
  "weekStart": ""
}
