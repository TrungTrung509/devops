
# BIẾN MÔI TRƯỜNG - CƠ SỞ DỮ LIỆU PHÂN TÁN
# Copy file này thành .env và chỉnh sửa giá trị

# SITE HADONG (Hà Nội)
# Port PostgreSQL của site Hà Nội
HADONG_PORT=5432

# Thông tin database
HADONG_DB=csdlpt_hadong
HADONG_USER=csdlpt_user
HADONG_PASSWORD=csdlpt_pass

# SITE NGOCTRUC (Ngọc Trục)
# Port PostgreSQL của site Ngọc Trục
NGOCTRUC_PORT=5433

# Thông tin database
NGOCTRUC_DB=csdlpt_ngoctruc
NGOCTRUC_USER=csdlpt_user
NGOCTRUC_PASSWORD=csdlpt_pass

# SITE HOALAC (Hòa Lạc)
# Port PostgreSQL của site Hòa Lạc
HOALAC_PORT=5434

# Thông tin database
HOALAC_DB=csdlpt_hoalac
HOALAC_USER=csdlpt_user
HOALAC_PASSWORD=csdlpt_pass

# POSTGRESQL TẬP TRUNG - Benchmark so sánh
# Port PostgreSQL của database tập trung
CENTRALIZED_PORT=5435

# Thông tin database tập trung
CENTRALIZED_DB=csdlpt_centralized
CENTRALIZED_USER=csdlpt_user
CENTRALIZED_PASSWORD=csdlpt_pass

# REDIS
# Port Redis
REDIS_PORT=6379

# ELASTICSEARCH
# Port Elasticsearch
ES_PORT=9200

# KIBANA
# Port Kibana Dashboard
KIBANA_PORT=5601

# BACKEND API
BACKEND_PORT=8000
REMOTE_BENCH_DELAY_MS=120

# MONITORING
# Port Prometheus
PROMETHEUS_PORT=9090

# Port Grafana Dashboard
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin123

# Port cAdvisor
CADVISOR_PORT=8085

# K6 BENCHMARK
BENCH_BASE_URL=http://backend:8000
BENCH_USERNAME=
BENCH_PASSWORD=
BENCH_TARGET_SITE=HADONG
BENCH_VUS=10
BENCH_ITERATIONS=100
BENCH_REMOTE_ITERATIONS=100


# KAFKA
# Port Kafka
KAFKA_PORT=9092

# Port Kafka UI Dashboard
KAFKA_UI_PORT=8090

# Port Kafka Connect
KAFKA_CONNECT_PORT=8083